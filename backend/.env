# ─── MongoDB ───────────────────────────────────────────────────────────────────
# Option 1: Local MongoDB
# MONGO_URL=mongodb://localhost:27017/food-delivery

# Option 2: MongoDB Atlas (free cloud DB) → get your URI from https://cloud.mongodb.com
# Replace <username>, <password>, <cluster> with your Atlas values
MONGO_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/food-delivery?retryWrites=true&w=majority

# ─── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production
SALT=10

# ─── Payments ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
